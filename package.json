{
	"name": "cvbruw",
	"version": "0.1.0",
	"description": "Monorepo for cvbruw: ATS-friendly resume generator and web editor.",
	"private": true,
	"workspaces": [
		"packages/*",
		"web"
	],
	"scripts": {
		"dev": "bun run --filter cvbruw-web dev",
		"build": "bun run --filter cvbruw-web build",
		"generate": "bun run --filter @cvbruw/generator generate",
		"format": "biome format",
		"lint": "biome lint",
		"check": "biome check",
		"test": "bun run --filter cvbruw-web test"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3"
	}
}
