{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "vite build",
  "installCommand": "bun install",
  "outputDirectory": "dist/client",
  "rewrites": [
    {
      "source": "/((?!assets|fonts|favicon\\.ico|logo|manifest|robots).*)",
      "destination": "/api/server"
    }
  ]
}
